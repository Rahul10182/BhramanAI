{
  "compilerOptions": {
    // 1. Un-commented these to cleanly separate your raw code from compiled code
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment settings
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],

    // Other outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter type-checking
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,

    // Interoperability (Highly recommended for Node.js backends and LangChain)
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // Module settings
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  // 2. Added these arrays so TS knows exactly what to compile and what to ignore
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}